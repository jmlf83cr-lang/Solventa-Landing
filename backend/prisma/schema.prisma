// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & USERS
// ============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  password          String
  firstName         String
  lastName          String
  role              UserRole       @default(VIEWER)
  status            UserStatus     @default(PENDING)
  organizationId    String?
  organization      Organization?  @relation(fields: [organizationId], references: [id])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lastLogin         DateTime?
  refreshToken      String?
  
  // Relations
  createdOrders     Order[]        @relation("CreatedByUser")
  createdMovements  Movement[]     @relation("CreatedByUser")
  auditLogs         AuditLog[]

  @@index([email])
  @@index([organizationId])
  @@map("users")
}

// ============================================
// ORGANIZATIONS & SUBSCRIPTIONS
// ============================================

enum PlanTier {
  EMPRENDEDOR
  PYME
  INVERSION
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

model Organization {
  id                String              @id @default(uuid())
  name              String
  rut               String?             @unique
  email             String
  phone             String?
  address           String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  users             User[]
  subscription      Subscription?
  warehouses        Warehouse[]
  products          Product[]
  auditLogs         AuditLog[]

  @@map("organizations")
}

model Plan {
  id                String              @id @default(uuid())
  tier              PlanTier            @unique
  name              String
  description       String?
  price             Decimal             @db.Decimal(10, 2)
  currency          String              @default("USD")
  
  // Features
  maxUsers          Int
  maxWarehouses     Int
  maxProducts       Int
  hasRealtimeSync   Boolean             @default(false)
  hasAdvancedReports Boolean            @default(false)
  hasAPIAccess      Boolean             @default(false)
  hasDigitalTwin    Boolean             @default(false)
  supportLevel      String              @default("email")
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  subscriptions     Subscription[]

  @@map("plans")
}

model Subscription {
  id                String              @id @default(uuid())
  organizationId    String              @unique
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId            String
  plan              Plan                @relation(fields: [planId], references: [id])
  status            SubscriptionStatus  @default(TRIAL)
  startDate         DateTime            @default(now())
  endDate           DateTime?
  trialEndsAt       DateTime?
  autoRenew         Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([organizationId])
  @@index([planId])
  @@map("subscriptions")
}

// ============================================
// WAREHOUSE MANAGEMENT SYSTEM (WMS)
// ============================================

enum WarehouseType {
  DISTRIBUTION
  PRODUCTION
  TRANSIT
  RETAIL
}

model Warehouse {
  id                String            @id @default(uuid())
  code              String            @unique
  name              String
  type              WarehouseType     @default(DISTRIBUTION)
  organizationId    String
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  address           String?
  city              String?
  country           String?
  capacity          Int?              // Capacidad en unidades o m³
  
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Relations
  inventory         Inventory[]
  orders            Order[]
  movements         Movement[]

  @@index([organizationId])
  @@index([code])
  @@map("warehouses")
}

enum ProductCategory {
  RAW_MATERIAL
  FINISHED_GOOD
  COMPONENT
  CONSUMABLE
  PACKAGING
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
  OUT_OF_STOCK
}

model Product {
  id                String            @id @default(uuid())
  sku               String            @unique
  name              String
  description       String?
  category          ProductCategory   @default(FINISHED_GOOD)
  status            ProductStatus     @default(ACTIVE)
  
  organizationId    String
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Attributes
  barcode           String?
  weight            Decimal?          @db.Decimal(10, 2)
  weightUnit        String?           @default("kg")
  dimensions        String?           // JSON: {length, width, height}
  
  // Pricing
  unitCost          Decimal?          @db.Decimal(10, 2)
  unitPrice         Decimal?          @db.Decimal(10, 2)
  currency          String            @default("USD")
  
  // Stock control
  minStockLevel     Int?              @default(0)
  maxStockLevel     Int?
  reorderPoint      Int?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Relations
  inventory         Inventory[]
  orderItems        OrderItem[]
  movements         Movement[]

  @@index([organizationId])
  @@index([sku])
  @@index([barcode])
  @@map("products")
}

model Inventory {
  id                String            @id @default(uuid())
  warehouseId       String
  warehouse         Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId         String
  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity          Int               @default(0)
  reservedQuantity  Int               @default(0) // Cantidad reservada para órdenes
  availableQuantity Int               @default(0) // quantity - reservedQuantity
  
  location          String?           // Ubicación física en el almacén (ej: "A-12-03")
  
  lastCountDate     DateTime?
  lastMovementDate  DateTime?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  @@unique([warehouseId, productId])
  @@index([warehouseId])
  @@index([productId])
  @@map("inventory")
}

enum OrderType {
  PURCHASE
  SALE
  TRANSFER
  RETURN
  ADJUSTMENT
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Order {
  id                String            @id @default(uuid())
  orderNumber       String            @unique
  type              OrderType
  status            OrderStatus       @default(DRAFT)
  
  warehouseId       String
  warehouse         Warehouse         @relation(fields: [warehouseId], references: [id])
  
  // Customer/Supplier info
  customerName      String?
  customerEmail     String?
  supplierName      String?
  
  // Metadata
  notes             String?
  totalAmount       Decimal?          @db.Decimal(12, 2)
  currency          String            @default("USD")
  
  // Dates
  orderDate         DateTime          @default(now())
  expectedDate      DateTime?
  completedDate     DateTime?
  
  createdById       String
  createdBy         User              @relation("CreatedByUser", fields: [createdById], references: [id])
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Relations
  items             OrderItem[]
  movements         Movement[]

  @@index([warehouseId])
  @@index([orderNumber])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                String            @id @default(uuid())
  orderId           String
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product           @relation(fields: [productId], references: [id])
  
  quantity          Int
  unitPrice         Decimal?          @db.Decimal(10, 2)
  totalPrice        Decimal?          @db.Decimal(12, 2)
  
  notes             String?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

enum MovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
  RETURN
}

model Movement {
  id                String            @id @default(uuid())
  type              MovementType
  
  warehouseId       String
  warehouse         Warehouse         @relation(fields: [warehouseId], references: [id])
  productId         String
  product           Product           @relation(fields: [productId], references: [id])
  
  quantity          Int
  fromLocation      String?
  toLocation        String?
  
  orderId           String?
  order             Order?            @relation(fields: [orderId], references: [id])
  
  notes             String?
  reference         String?           // Reference number (LPN, IDL, etc.)
  
  createdById       String
  createdBy         User              @relation("CreatedByUser", fields: [createdById], references: [id])
  
  movementDate      DateTime          @default(now())
  createdAt         DateTime          @default(now())

  @@index([warehouseId])
  @@index([productId])
  @@index([orderId])
  @@index([movementDate])
  @@map("movements")
}

// ============================================
// AUDIT & LOGGING
// ============================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ACCESS
}

model AuditLog {
  id                String            @id @default(uuid())
  action            AuditAction
  entity            String            // Nombre de la entidad afectada (User, Product, etc.)
  entityId          String?           // ID de la entidad
  
  userId            String?
  user              User?             @relation(fields: [userId], references: [id])
  organizationId    String?
  organization      Organization?     @relation(fields: [organizationId], references: [id])
  
  changes           String?           // JSON con los cambios realizados
  ipAddress         String?
  userAgent         String?
  
  createdAt         DateTime          @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
